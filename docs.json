{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ares",
  "description": "Documentation for Ares, the AI operator that runs marketing and lead follow-up for home-service businesses.",
  "colors": {
    "primary": "#FF0000",
    "light": "#FF3333",
    "dark": "#C40000"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#0C0C0C"
    }
  },
  "logo": {
    "light": "/logo/ares.svg",
    "dark": "/logo/ares.svg"
  },
  "favicon": "/logo/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Connections",
        "pages": ["connections/crm", "connections/ads"]
      },
      {
        "group": "Using Ares",
        "pages": ["using/dashboard", "using/chat", "using/approvals", "using/leads"]
      },
      {
        "group": "Account",
        "pages": ["account/billing", "account/faq", "account/troubleshooting"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.aresdeploy.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Ares",
      "href": "https://aresdeploy.com"
    }
  },
  "footer": {
    "socials": {}
  }
}
